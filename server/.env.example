# server/.env.example
# Copy this file to .env and fill in the values.
# All service ports are defined here so there are no hard-coded defaults
# scattered across the code. Changing a port in one place is enough.

# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001                            # Express server port

# ─── Security (REQUIRED — generate with: openssl rand -hex 32) ───────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d
ENCRYPTION_SECRET=your_32_char_hex_encryption_secret

# ─── Database: MongoDB ───────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/imentor

# ─── Database: Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379                      # Discrete port var (used by health checks)

# ─── Database: Neo4j (Knowledge Graph) ───────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_PORT=7687

# ─── Database: Qdrant (Vector Store) ─────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333

# ─── Database: Elasticsearch ─────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_PORT=9200

# ─── Python RAG Microservice ─────────────────────────────────────────────────
# API_PORT in rag_service/config.py defaults to 2001 — keep in sync
PYTHON_RAG_SERVICE_URL=http://localhost:2001
RAG_PORT=2001

# ─── SGLang (OpenAI-compatible local LLM) ─────────────────────────────────────
# All LLM inference uses SGLang. Ollama has been fully removed.
SGLANG_ENABLED=true
SGLANG_CHAT_URL=http://localhost:8000/v1
SGLANG_REASON_URL=http://localhost:8000/v1
SGLANG_HEAVY_URL=http://localhost:8000/v1
SGLANG_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
SGLANG_REASON_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
SGLANG_HEAVY_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
GPU_TOTAL_VRAM_GB=16

# ─── Frontend Origin (CORS) ──────────────────────────────────────────────────
# Comma-separated list of allowed origins. Localhost ports are allowed by default
# via regex; add production origins here.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=http://localhost:5173,https://yourdomain.com

# ─── LLM Provider API Keys ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key
CLAUDE_API_KEY=your_claude_api_key
MISTRAL_API_KEY=your_mistral_api_key

# ─── Email / SMTP ────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=iMentor <your_email@gmail.com>

# ─── Authentication: Development Mode ────────────────────────────────────────
# EMAIL_VERIFICATION_REQUIRED=false    # Set to 'false' for development (no SMTP needed)
# When false:
#   - Signup skips OTP verification
#   - Email service is not required
#   - Users are auto-verified and can login immediately
# Default: true (production-safe, requires email service)

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_SETUP_KEY=your_admin_setup_key

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=                          # Optional: Sentry error tracking DSN
