# frontend/.env.example
# Copy this file to .env and fill in the values.
# All port references for backend services are defined here.
# Change once here — no scattered port numbers in source code.

# ─── Backend API ─────────────────────────────────────────────────────────────
# Must match server/.env PORT (default 5001)
VITE_API_BASE_URL=http://localhost:5001/api

# ─── WebSocket ───────────────────────────────────────────────────────────────
# Used by socket.io client to connect for real-time streaming
VITE_WS_URL=ws://localhost:5001

# ─── Python RAG Microservice (if called directly from the browser) ────────────
# Usually only called server-side; expose here for dev tools / debugging
VITE_PYTHON_RAG_URL=http://localhost:8001

# ─── Qdrant (only needed if frontend visualisation tools query it directly) ───
VITE_QDRANT_URL=http://localhost:6335

# ─── App Environment ─────────────────────────────────────────────────────────
VITE_NODE_ENV=development

# ─── Feature Flags (optional) ────────────────────────────────────────────────
# VITE_ENABLE_DEBUG_PANEL=true
